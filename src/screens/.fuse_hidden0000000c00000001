    cancelText: { fontSize: 15, fontWeight: "600", color: c.text2 },
    delBtn: { flex: 1, paddingVertical: 14, borderRadius: radii.btn, borderWidth: 1, borderColor: c.amberBorder, alignItems: "center" },
